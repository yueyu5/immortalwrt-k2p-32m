# ==============================
# 设备核心配置：Phicomm K2P
# ==============================
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_phicomm_k2p=y

# 固件基础优化
CONFIG_TARGET_OPTIMIZATION="-O2 -pipe -march=24kc -mtune=24kc"
CONFIG_STRIP_KERNEL_EXPORTS=y

# 极限压缩，减小固件体积
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_SQUASHFS_COMP_XZ=y
CONFIG_SQUASHFS_XZ_PRESET=9

# 对于128M内存优化
# 内存优化
CONFIG_LOW_MEMORY_FOOTPRINT=y
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
# ZRAM 配置
CONFIG_ZRAM=y
CONFIG_ZRAM_SWAP=y
CONFIG_ZRAM_SIZE=32M
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZRAM_MEMORY_POOL=y
CONFIG_ZRAM_LZ4_COMPRESS=y
CONFIG_CRYPTO_LZ4=y
CONFIG_CRYPTO_LZ4HC=y
CONFIG_VM_SWAPPINESS=25
# 网络优化
CONFIG_NF_CONNTRACK_MAX=4096
CONFIG_TCP_MEM_MIN=4096
CONFIG_TCP_MEM_DEFAULT=8192

CONFIG_PACKAGE_tc=y
CONFIG_PACKAGE_iptables-mod-fullconenat=y
CONFIG_PACKAGE_kmod-tcp-bbr=y      # BBR 拥塞控制
CONFIG_PACKAGE_ipv6helper=y         # IPv6 支持

# ==============================
# LuCI 基础配置（中文界面）
# ==============================
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-compat=y

# ==============================
# DNS (Standard dnsmasq, not full version)
CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_dnsmasq-full=n
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y


# 仅保留PassWall核心
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
 # ========== 只开启 VMess + Shadowsocks 强制关闭所有其他协议 ==========
CONFIG_PASSWALL_INCLUDE_SS=y
CONFIG_PASSWALL_INCLUDE_VMESS=y
 # 禁用多余协议
 # CONFIG_PASSWALL_INCLUDE_VLESS is not set
 # CONFIG_PASSWALL_INCLUDE_TROJAN is not set
 # CONFIG_PASSWALL_INCLUDE_HYSTERIA is not set
 CONFIG_PASSWALL_INCLUDE_SOCKS5=y
 # CONFIG_PASSWALL_INCLUDE_TUIC is not set
 # 精简依赖省空间
CONFIG_PACKAGE_shadowsocks-libev=y
CONFIG_PACKAGE_v2ray-core=y

# ==============================
# 关闭所有多余组件（进一步减小体积）
# ==============================
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-samba4=n
CONFIG_PACKAGE_htop=n
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_nano=n
CONFIG_PACKAGE_block-mount=n
CONFIG_PACKAGE_kmod-fs-ext4=n

CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-wol=y
# 启用阿里云 DDNS 的 LuCI 界面
CONFIG_PACKAGE_luci-app-aliddns=y

#Argon 主题 + 主题设置
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
# 设置默认主题
CONFIG_LUCI_DEFAULT_THEME="argon"


