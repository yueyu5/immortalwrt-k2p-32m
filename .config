# ==============================
# 设备核心配置：Phicomm K2P
# ==============================
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_phicomm_k2p=y

# 固件基础优化
CONFIG_TARGET_OPTIMIZATION="-O2 -pipe -march=24kc -mtune=24kc"
CONFIG_USE_MKLIBS=y
CONFIG_STRIP_KERNEL_EXPORTS=y

# 极限压缩，减小固件体积
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_SQUASHFS_COMP_XZ=y
CONFIG_SQUASHFS_XZ_PRESET=9

# ==============================
# LuCI 基础配置（中文界面）
# ==============================
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-compat=y

#【核心】完全禁用开源mt76驱动（避免冲突）
# ==============================
CONFIG_PACKAGE_kmod-mt76=n
CONFIG_PACKAGE_kmod-mt76-core=n
CONFIG_PACKAGE_kmod-mt76-connac=n
CONFIG_PACKAGE_kmod-mt7615-common=n
CONFIG_PACKAGE_kmod-mt7615e=n
CONFIG_PACKAGE_kmod-mt7615-firmware=n
CONFIG_PACKAGE_wpad-basic-mbedtls=n
CONFIG_PACKAGE_hostapd-common=n
 # ==============================
 # 【核心】启用mt7615闭源无线驱动
 # ==============================
CONFIG_PACKAGE_kmod-mt_wifi=y
CONFIG_PACKAGE_wifi-l1profile=y
CONFIG_PACKAGE_luci-app-mtwifi=y
CONFIG_PACKAGE_uci2dat=y
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_hostapd-openssl=y
CONFIG_PACKAGE_wpa_supplicant-openssl=y

# ==============================
# 必需依赖（SSR-Plus 必备）
# ==============================
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq-full_cryptohash=y
CONFIG_PACKAGE_dnsmasq-full_ipset=y
CONFIG_PACKAGE_dnsmasq-full_nftset=y

CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-bin=y

# ==============================
# SSR-Plus 极简配置（仅 SS/SSR/VMess）
# ==============================
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-i18n-ssr-plus-zh_Hans=y

# 核心开启：仅保留你需要的 3 种协议
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Libev_Client=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Libev_Client=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=y

# 关闭所有其他协议/核心（极致瘦身，减小固件体积）
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Sing_box=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Hysteria=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Trojan=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_NaiveProxy=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_V2ray_Plugin=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Tuic=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Brook=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Redsocks2=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Simple_Obfs=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_V2ray_Plugin=n

# ==============================
# 关闭所有多余组件（进一步减小体积）
# ==============================
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-samba4=n
CONFIG_PACKAGE_htop=n
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_nano=n
CONFIG_PACKAGE_block-mount=n
CONFIG_PACKAGE_kmod-fs-ext4=n

CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh_Hans=y

CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-i18n-arpbind-zh_Hans=y

CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh_Hans=y
